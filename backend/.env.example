# Database - use SQLite for local dev, PostgreSQL for production
DATABASE_URL=sqlite:///./outfit.db

# JWT - use a random secret in production
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Stripe - get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_PUBLISHABLE_KEY=pk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# OpenWeatherMap - get from https://openweathermap.org/api
WEATHER_API_KEY=your-weather-api-key

# Optional
UPLOAD_DIR=uploads
DEFAULT_ADMIN_EMAIL=admin@outfit.com
DEFAULT_ADMIN_PASSWORD=admin123
